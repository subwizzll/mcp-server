# ─── Open Brain MCP Server ──────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
# Use the service role key so the MCP server can read and write brain_memories
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
SUPABASE_ANON_KEY="your_supabase_anon_key"
# ─── OpenRouter (Embeddings) ──────────────────────────────────
OPENROUTER_API_KEY="your_openrouter_api_key"

# ─── Embedding Config ─────────────────────────────────────────
EMBEDDING_MODEL="openai/text-embedding-3-small"
EMBEDDING_DIMENSIONS=1536

# ─── SSE/HTTP Transport ───────────────────────────────────────
# Port for the HTTP/SSE server (dev:http / start:http)
MCP_HTTP_PORT=3100

# ─── Edge Function ────────────────────────────────────────────
# Override if not using standard Supabase URL pattern
# SUPABASE_EDGE_FUNCTION_URL="https://your-project.supabase.co/functions/v1"
